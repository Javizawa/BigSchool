# Frontend — BigSchool
# Copia este fichero como .env y rellena los valores reales.
# Las variables con prefijo NG_APP_ se exponen en el build de Angular.
# NUNCA subas .env al repositorio.

# ── Supabase ─────────────────────────────────────────────────────────────────
NG_APP_SUPABASE_URL=https://<project-ref>.supabase.co
NG_APP_SUPABASE_ANON_KEY=eyJ...

# ── Cloudinary ───────────────────────────────────────────────────────────────
NG_APP_CLOUDINARY_CLOUD_NAME=tu-cloud-name
NG_APP_CLOUDINARY_UPLOAD_PRESET=bigschool_unsigned

# ── Stripe (clave pública — safe to expose) ──────────────────────────────────
NG_APP_STRIPE_PUBLISHABLE_KEY=pk_test_...
