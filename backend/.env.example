# Backend — BigSchool
# Copia este fichero como .env y rellena los valores reales.
# NUNCA subas .env al repositorio.

# ── Servidor ────────────────────────────────────────────────────────────────
PORT=3000
CORS_ORIGIN=http://localhost:4200

# ── Base de datos (Supabase PostgreSQL) ─────────────────────────────────────
# Connection string pooler (transaccional) — para Prisma en runtime
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# Direct connection — para Prisma migrate
DIRECT_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# ── Supabase Auth ────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=eyJ...

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
