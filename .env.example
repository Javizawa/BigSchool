# ===========================================================================
# BigSchool — Variables de entorno
# ===========================================================================
# Copia este archivo como .env en la raíz del proyecto que corresponda
# (backend/.env o frontend/.env) y rellena los valores reales.
# NUNCA commits el archivo .env — está en .gitignore.
# ===========================================================================


# ---------------------------------------------------------------------------
# BACKEND (backend/.env)
# ---------------------------------------------------------------------------

# Entorno de ejecución
NODE_ENV=development
PORT=3000

# --- Supabase ---
# Obtenibles en: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# --- Cloudinary ---
# Obtenibles en: Cloudinary Dashboard → Settings → Access Keys
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# --- Stripe ---
# Obtenibles en: Stripe Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
# Obtenable en: Stripe Dashboard → Developers → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret

# --- CORS ---
CORS_ORIGIN=http://localhost:4200


# ---------------------------------------------------------------------------
# FRONTEND (frontend/.env o src/environments/environment.ts)
# ---------------------------------------------------------------------------
# En Angular, las variables públicas se configuran en environment.ts.
# Las variables con prefijo NG_APP_ son accesibles via @angular/build.

NG_APP_API_URL=http://localhost:3000/api/v1

# --- Supabase (clave pública) ---
NG_APP_SUPABASE_URL=https://your-project-id.supabase.co
NG_APP_SUPABASE_ANON_KEY=your-anon-key

# --- Stripe (clave pública) ---
NG_APP_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# --- Cloudinary (upload preset, sin API secret) ---
NG_APP_CLOUDINARY_CLOUD_NAME=your-cloud-name
NG_APP_CLOUDINARY_UPLOAD_PRESET=your-unsigned-upload-preset
